# =====================================================
# AIW Content Engine — environment template
# =====================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local. The .gitignore already excludes it.

# ----- Supabase (required to run the app at all) -----
# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic Claude (optional in dev, required for real generation) -----
# Get from https://console.anthropic.com
# When missing: app runs in demo mode with stub responses
ANTHROPIC_API_KEY=

# ----- Apify (optional in dev, required for Instagram + TikTok scraping) -----
# Get from https://console.apify.com/account/integrations
# When missing: reel ingestion and Radar fall back to stub data
APIFY_API_TOKEN=

# ----- AssemblyAI (optional in dev, required for reel audio transcription) -----
# Get from https://www.assemblyai.com/app/account
# When missing: reels are stored with caption only, transcript marked pending
ASSEMBLYAI_API_KEY=

# ----- App URL (required for AssemblyAI + Apify webhook callbacks) -----
# Your publicly reachable deployment URL, no trailing slash.
# Example: https://aiwcontentengine.vercel.app
# Required for: audio/video transcription via AssemblyAI, Instagram + TikTok
# scraping via Apify. Both services need to call back into the app and cannot
# reach localhost. For local dev, run `ngrok http 3005` and paste the https URL.
NEXT_PUBLIC_APP_URL=

# ----- Cron secret (required in production for Vercel Cron auth) -----
# Generate with: openssl rand -hex 32
# Cron jobs verify this header to reject spurious requests
CRON_SECRET=

# ----- Webhook secret (recommended once deployed) -----
# Generate with: openssl rand -hex 32
# Outbound webhook URLs to AssemblyAI and Apify carry ?secret=... and the
# inbound webhook routes verify it. When unset, the routes log a warning
# and accept all callbacks (useful for first deploy, not for production).
WEBHOOK_SECRET=
