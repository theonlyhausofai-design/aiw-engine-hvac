    "src/app/api/setup/propose-expert/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/radar/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/performance/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/recover-stuck/route.ts": { "maxDuration": 300 },
    "src/app/api/generate/route.ts": { "maxDuration": 120 },
    "src/app/api/webhooks/apify/route.ts": { "maxDuration": 300 },
    "src/app/api/radar/scan/route.ts": { "maxDuration": 300 },
